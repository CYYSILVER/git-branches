#!/usr/bin/env zsh
#
# git-branches — interactive branch selector with descriptions
#
#   j / k / ↑ / ↓   navigate
#   enter            checkout selected branch
#   space            toggle mark (single)
#   v                visual range select (vim-like)
#   c                create new branch (with description)
#   d                delete selected / marked / visual range
#   r                edit description for selected branch
#   /                search / filter branches
#   q / esc          quit
#
# Language: set GIT_BRANCHES_LANG=en for English (default: zh)

setopt LOCAL_OPTIONS NO_NOTIFY NO_MONITOR 2>/dev/null

# ─── Appearance ───────────────────────────────────────
typeset -r _R=$'\e[0m'
typeset -r _B=$'\e[1m'
typeset -r _D=$'\e[2m'
typeset -r _FG=$'\e[32m'
typeset -r _FC=$'\e[36m'
typeset -r _FY=$'\e[33m'
typeset -r _FR=$'\e[31m'
typeset -r _FW=$'\e[97m'
typeset -r _HL=$'\e[48;5;238m'
typeset -r _HC=$'\e[48;5;23m'
typeset -r _HIDE=$'\e[?25l'
typeset -r _SHOW=$'\e[?25h'

# ─── i18n ─────────────────────────────────────────────
typeset -gA _L

_i18n_zh() {
    _L=(
        title            "Git 分支"
        hint_normal      "· j/k ↑↓ · ⏎ 切换 · ␣ 标记 · v 选区 · / 搜索 · c 新建 · d 删除 · r 描述 · q 退出"
        hint_visual      "· j/k ↑↓ 扩展 · ␣ 标记选区 · d 删除选区 · esc 取消"
        hint_search      "· ↑↓ 移动 · 回车切换 · esc 取消"
        hint_create      "· 回车确认 · esc 取消"
        hint_create_desc "· 回车确认 · esc 跳过"
        hint_delete      "· y 确认删除 · 其他键取消"
        no_match         "没有匹配的分支"
        branch_name      "分支名称:"
        description      "分支描述:"
        delete_single    '删除 "%s" ?'
        delete_multi     '删除 %d 个标记的分支 ?'
        visual_footer    '已选择 %d 个分支'
        marked_footer    '%d 个已标记 · d 删除标记 · esc 清除标记'
        filter_footer    '(%d/%d · 筛选: "%s" · esc 清除)'
        msg_no_mark_cur  "无法标记当前分支"
        msg_no_del_cur   "无法删除当前分支"
        msg_created      "已创建 '%s'"
        msg_deleted      "已删除 '%s'"
        msg_deleted_n    '已删除 %d 个分支'
        msg_failed       ', %d 个失败'
        msg_already_on   "已在 '%s' 分支上"
        err_not_repo     "错误: 不是 git 仓库"
        err_no_branch    "没有找到分支"
        err_not_tty      "错误: 需要交互式终端"
    )
}

_i18n_en() {
    _L=(
        title            "Git Branches"
        hint_normal      "· j/k ↑↓ · ⏎ checkout · ␣ mark · v select · /search · c new · d del · r desc · q quit"
        hint_visual      "· j/k ↑↓ extend · ␣ mark range · d del range · esc cancel"
        hint_search      "· ↑↓ navigate · enter checkout · esc cancel"
        hint_create      "· enter confirm · esc cancel"
        hint_create_desc "· enter confirm · esc skip"
        hint_delete      "· y confirm delete · any other key cancel"
        no_match         "No matching branches"
        branch_name      "Branch name:"
        description      "Description:"
        delete_single    'Delete "%s" ?'
        delete_multi     'Delete %d marked branches ?'
        visual_footer    '%d branch(es) selected'
        marked_footer    '%d marked · d delete marked · esc clear marks'
        filter_footer    '(%d/%d · filter: "%s" · esc clear)'
        msg_no_mark_cur  "Cannot mark the current branch"
        msg_no_del_cur   "Cannot delete the current branch"
        msg_created      "Created '%s'"
        msg_deleted      "Deleted '%s'"
        msg_deleted_n    'Deleted %d branch(es)'
        msg_failed       ', %d failed'
        msg_already_on   "Already on '%s'"
